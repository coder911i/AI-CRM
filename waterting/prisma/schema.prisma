generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────
enum Plan {
  STARTER
  GROWTH
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  AGENCY_OWNER
  SALES_MANAGER
  SALES_AGENT
  BROKER
  BUYER
  BUILDER
  PROPERTY_OWNER
  ACCOUNTS
}

enum LeadStage {
  NEW_LEAD
  CONTACTED
  INTERESTED
  VISIT_SCHEDULED
  VISIT_DONE
  NEGOTIATION
  BOOKING_DONE
  LOST
}

enum LeadSource {
  WEBSITE
  LANDING_PAGE
  FACEBOOK
  GOOGLE
  WHATSAPP
  PORTAL_99ACRES
  PORTAL_MAGICBRICKS
  PORTAL_HOUSING
  MANUAL
  BROKER
  QR_CODE
}

enum ScoreLabel {
  COLD
  WARM
  HOT
  VERY_HOT
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  BOOKED
  SOLD
  BLOCKED
}

enum UnitType {
  ONE_BHK
  TWO_BHK
  THREE_BHK
  FOUR_BHK
  STUDIO
  PENTHOUSE
  VILLA
  PLOT
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
  VILLA
  TOWNSHIP
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  UPCOMING
  ON_HOLD
}

enum PaymentMethod {
  UPI
  NEFT
  RTGS
  CHEQUE
  CASH
  DEMAND_DRAFT
}

enum BookingStatus {
  INITIATED
  PAYMENT_PENDING
  CONFIRMED
  CANCELLED
}

enum VisitOutcome {
  INTERESTED
  NOT_INTERESTED
  NEED_MORE_TIME
  BOOKED
  NO_SHOW
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  NOTE
  STAGE_CHANGE
  VISIT_SCHEDULED
  VISIT_COMPLETED
  DOCUMENT_SHARED
  AI_ACTION
}

// ── Core Models ────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String
  plan        Plan     @default(STARTER)
  settings    Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  projects    Project[]
  leads       Lead[]
  brokers     Broker[]
  automations Automation[]
  embeddings  Embedding[]
  notifications Notification[]
  auditLogs     AuditLog[]   @relation("TenantAuditLogs")
  listings      Listing[]
  agencies      Agency[]
  properties    Property[]
  supportTickets SupportTicket[]
  ads           Ad[]
}

model User {
  id          String   @id @default(cuid())
  tenantId    String
  agencyId    String?
  role        UserRole @default(SALES_AGENT)
  email       String
  name        String
  phone       String?
  agentCode   String?
  password    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  agency      Agency?    @relation(fields: [agencyId], references: [id])
  leads       Lead[]     @relation("AssignedLeads")
  activities  Activity[]
  siteVisits  SiteVisit[]
  brokerVisits PropertyVisit[] @relation("BrokerVisit")
  customerVisits PropertyVisit[] @relation("CustomerVisit")
  ownedProperties Property[] @relation("PropertyOwner")
  notifications Notification[]
  auditLogs     AuditLog[]
  commissions   Commission[]
  wishlist      Wishlist[]
  supportTickets SupportTicket[]
  ticketMessages TicketMessage[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([agencyId])
}

model Project {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  location    String
  latitude    Float?
  longitude   Float?
  reraNumber  String?
  type        ProjectType
  status      ProjectStatus @default(ACTIVE)
  launchDate  DateTime?
  amenities   String[]
  upiQrUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  towers              Tower[]
  leads               Lead[]
  media               ProjectMedia[]
  constructionUpdates ConstructionUpdate[]
  listings            Listing[]
  ads                 Ad[]
  wishlistedBy        Wishlist[]

  @@index([tenantId])
}

model ProjectMedia {
  id        String   @id @default(cuid())
  projectId String
  type      String // BROCHURE, WALKTHROUGH, IMAGE
  url       String
  title     String?
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model ConstructionUpdate {
  id            String   @id @default(cuid())
  projectId     String
  milestoneName String
  description   String?
  photoUrls     String[]
  progressPct   Int      @default(0)
  updateDate    DateTime @default(now())
  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model Tower {
  // ... existing fields ...
  id          String  @id @default(cuid())
  projectId   String
  name        String
  totalFloors Int
  createdAt   DateTime @default(now())

  project     Project @relation(fields: [projectId], references: [id])
  floors      Floor[]
  units       Unit[]

  @@index([projectId])
}

model Floor {
  id           String   @id @default(cuid())
  towerId      String
  floorNumber  Int
  totalUnits   Int      @default(0)
  floorPlanUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tower        Tower    @relation(fields: [towerId], references: [id])
  units        Unit[]

  @@index([towerId])
}

model Unit {
  // ... existing fields ...
  id           String     @id @default(cuid())
  towerId      String
  floor        Int
  unitNumber   String
  type         UnitType
  carpetArea   Float
  superArea    Float?
  facing       String?
  basePrice    Float
  totalPrice   Float
  status       UnitStatus @default(AVAILABLE)
  floorPlanUrl String?
  holdUntil    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tower        Tower     @relation(fields: [towerId], references: [id])
  floorId      String?
  floorRel     Floor?    @relation(fields: [floorId], references: [id])
  bookings     Booking[]

  @@index([towerId])
  @@index([floorId])
  @@index([status])
}

model Lead {
  // ... existing fields ...
  id              String      @id @default(cuid())
  tenantId        String
  projectId       String?
  assignedToId    String?
  brokerId        String?
  name            String
  phone           String
  email           String?
  source          LeadSource  @default(MANUAL)
  stage           LeadStage   @default(NEW_LEAD)
  score           Int?
  scoreLabel      ScoreLabel?
  budgetMin       Float?
  budgetMax       Float?
  preferredBHK    String?
  timeline        String?
  notes           String?
  utmSource       String?
  utmCampaign     String?
  emailOptOut     Boolean     @default(false)
  isArchived      Boolean     @default(false)
  lastActivityAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  project         Project?    @relation(fields: [projectId], references: [id])
  assignedTo      User?       @relation("AssignedLeads", fields: [assignedToId], references: [id])
  broker          Broker?     @relation(fields: [brokerId], references: [id])
  agency          Agency?     @relation("AgencyLeads", fields: [agencyId], references: [id])
  agencyId        String?
  activities      Activity[]
  siteVisits      SiteVisit[]
  bookings        Booking[]
  embeddings      Embedding[]
  buyerPreference BuyerPreference?
  allocationLogs  AllocationLog[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@index([score])
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String?
  userId      String?
  type        ActivityType
  title       String
  description String?
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  lead        Lead?   @relation(fields: [leadId], references: [id])
  user        User?  @relation(fields: [userId], references: [id])

  @@index([leadId])
}

model SiteVisit {
  // ... existing fields ...
  id            String        @id @default(cuid())
  leadId        String
  agentId       String?
  scheduledAt   DateTime
  outcome       VisitOutcome?
  notes         String?
  followUpDate  DateTime?
  checkInTime   DateTime?
  checkOutTime  DateTime?
  verificationToken String? @default(cuid())
  metadata      Json          @default("{}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lead          Lead   @relation(fields: [leadId], references: [id])
  agent         User?  @relation(fields: [agentId], references: [id])

  @@index([leadId])
  @@index([scheduledAt])
}

model Broker {
  // ... existing fields ...
  id            String  @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  email         String?
  reraNumber    String?
  commissionPct Float   @default(2.0)
  referralCode  String  @unique @default(cuid())
  isActive      Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  leads         Lead[]
  commissions   Commission[]
  disputes      BrokerDispute[]
  allocationLogs AllocationLog[]

  @@index([tenantId])
}

model Booking {
  id              String        @id @default(cuid())
  unitId          String
  leadId          String
  buyerName       String
  buyerPhone      String
  buyerEmail      String?
  nomineeName     String?
  bookingAmount   Float
  gstRate         Float         @default(5.0)
  gstAmount       Float         @default(0)
  grandTotal      Float         @default(0)
  status          BookingStatus @default(INITIATED)
  isVerified      Boolean       @default(false)
  documents       String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  unit            Unit      @relation(fields: [unitId], references: [id])
  lead            Lead      @relation(fields: [leadId], references: [id])
  payments        Payment[]
  commissions     Commission[]
  coBuyers        CoBuyer[]
  refunds         Refund[]

  @@index([leadId])
  @@index([unitId])
}

model CoBuyer {
  id          String   @id @default(cuid())
  bookingId   String
  name        String
  phone       String
  email       String?
  relation    String? // SPOUSE, PARTNER, PARENT, etc.
  createdAt   DateTime @default(now())

  booking     Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Refund {
  id              String   @id @default(cuid())
  bookingId       String
  amount          Float
  reason          String?
  status          String   @default("PENDING") // PENDING, PROCESSED, REJECTED
  referenceNumber String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  booking         Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  receiptNumber   String?       @unique
  amount          Float
  dueDate         DateTime
  paidAt          DateTime?
  method          PaymentMethod?
  referenceNumber String?
  receiptUrl      String?
  isVerified      Boolean       @default(false) // Approved by Accounts role
  isOverdue       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  booking         Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([dueDate])
}

model Commission {
  id          String   @id @default(cuid())
  brokerId    String?
  userId      String?  // Internal Sales Agent
  bookingId   String
  amount      Float
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  broker      Broker?  @relation(fields: [brokerId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  booking     Booking @relation(fields: [bookingId], references: [id])

  @@index([brokerId])
  @@index([userId])
}

model Automation {
  // ... existing fields ...
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  trigger     String
  conditions  Json     @default("[]")
  actions     Json     @default("[]")
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant      Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Embedding {
  id          String   @id @default(cuid())
  tenantId    String
  leadId      String?
  unitId      String?
  embedding   String?  // stored as JSON array — pgvector not required
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  lead        Lead?  @relation(fields: [leadId], references: [id])

  @@index([tenantId])
}

model Notification {
  // ... existing fields ...
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  message   String
  type      String   @default("SYSTEM")
  leadId    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  user      User   @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([tenantId])
}

model BrokerDispute {
  // ... existing fields ...
  id          String   @id @default(cuid())
  tenantId    String
  brokerId    String
  leadId      String
  reason      String
  status      String   @default("OPEN")
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  broker      Broker @relation(fields: [brokerId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  entity      String
  entityId    String
  oldData     Json?
  newData     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?  @relation(fields: [userId], references: [id])
  tenant      Tenant @relation(fields: [tenantId], references: [id], name: "TenantAuditLogs")
}

model Listing {
  id            String   @id @default(cuid())
  tenantId      String
  projectId     String?
  title         String
  description   String?
  price         Float
  platform      String   // 99ACRES, MAGICBRICKS, HOUSING, WEBSITE
  platformId    String?  // ID on the external platform
  status        String   @default("ACTIVE")
  syncStatus    Json?    @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  project       Project? @relation(fields: [projectId], references: [id])
  ads           Ad[]

  @@index([tenantId])
  @@index([platform])
}model Agency {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  logoUrl     String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  members     User[]
  leads       Lead[] @relation("AgencyLeads")

  @@index([tenantId])
}

model Property {
  id          String    @id @default(cuid())
  tenantId    String
  ownerId     String
  title       String
  description String?
  type        String    // APARTMENT, VILLA, PLOT, etc.
  status      String    @default("AVAILABLE")
  price       Float
  location    String
  address     String?
  amenities   String[]
  images      String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bhk             Int?
  areaSqft        Float?
  furnishing      String?
  possessionDate  DateTime?
  rentAmount      Float?
  reraNumber      String?
  videoUrl        String?
  embedding       String?
  featuredUntil   DateTime?
  latitude        Float?
  longitude       Float?
  assignedBrokerIds String[]

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  owner       User           @relation("PropertyOwner", fields: [ownerId], references: [id])
  visits      PropertyVisit[]
  wishlistedBy Wishlist[]

  @@index([tenantId])
  @@index([ownerId])
}

model PropertyVisit {
  id          String       @id @default(cuid())
  propertyId  String
  brokerId    String
  customerId  String
  scheduledAt DateTime
  status      String       @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  property    Property     @relation(fields: [propertyId], references: [id])
  broker      User         @relation(fields: [brokerId], references: [id], name: "BrokerVisit")
  customer    User         @relation(fields: [customerId], references: [id], name: "CustomerVisit")

  @@index([propertyId])
  @@index([brokerId])
  @@index([customerId])
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String   // email or phone
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model AllocationLog {
  id                  String           @id @default(cuid())
  tenantId            String
  propertyId          String?
  leadId              String
  buyerId             String?
  brokerId            String?
  ownerId             String?
  watertaingAgentId   String?
  status              AllocationStatus @default(PENDING)
  fraudFlag           Boolean          @default(false)
  fraudNote           String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  lead        Lead          @relation(fields: [leadId], references: [id])
  broker      Broker?       @relation(fields: [brokerId], references: [id])
  visitSlots  VisitSlot[]

  @@index([tenantId])
  @@index([brokerId])
  @@index([watertaingAgentId])
}

enum AllocationStatus {
  PENDING
  BROKER_ASSIGNED
  VISIT_PROPOSED
  VISIT_CONFIRMED
  IN_NEGOTIATION
  BOOKING_DONE
  FRAUD_FLAGGED
  CLOSED
}

model VisitSlot {
  id            String        @id @default(cuid())
  allocationId  String
  proposedAt    DateTime
  isConfirmed   Boolean       @default(false)
  confirmedBy   String?
  createdAt     DateTime      @default(now())

  allocation    AllocationLog @relation(fields: [allocationId], references: [id])
}

model BuyerPreference {
  id              String   @id @default(cuid())
  leadId          String   @unique
  budgetMin       Float?
  budgetMax       Float?
  locationPref    String?
  bhk             String?
  purpose         String?
  amenities       String[]
  possessionBy    String?
  rawConversation Json     @default("[]")
  updatedAt       DateTime @updatedAt

  lead            Lead     @relation(fields: [leadId], references: [id])
}

model SupportTicket {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  subject     String
  description String?
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  user        User            @relation(fields: [userId], references: [id])
  messages    TicketMessage[]

  @@index([tenantId])
  @@index([userId])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model Wishlist {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  propertyId  String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  property    Property? @relation(fields: [propertyId], references: [id])

  @@unique([userId, projectId, propertyId])
}

model Ad {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String?
  listingId   String?
  title       String
  platform    String   // FACEBOOK, GOOGLE, INSTAGRAM
  status      String   @default("ACTIVE")
  budget      Float?
  spend       Float?   @default(0)
  clicks      Int?     @default(0)
  leads       Int?     @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  listing     Listing? @relation(fields: [listingId], references: [id])

  @@index([tenantId])
}

