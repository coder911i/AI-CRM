generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────
enum Plan {
  STARTER
  GROWTH
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  SALES_MANAGER
  SALES_AGENT
  ACCOUNTS
  BROKER
}

enum LeadStage {
  NEW_LEAD
  CONTACTED
  INTERESTED
  VISIT_SCHEDULED
  VISIT_DONE
  NEGOTIATION
  BOOKING_DONE
  LOST
}

enum LeadSource {
  WEBSITE
  LANDING_PAGE
  FACEBOOK
  GOOGLE
  WHATSAPP
  PORTAL_99ACRES
  PORTAL_MAGICBRICKS
  PORTAL_HOUSING
  MANUAL
  BROKER
  QR_CODE
}

enum ScoreLabel {
  COLD
  WARM
  HOT
  VERY_HOT
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  BOOKED
  SOLD
  BLOCKED
}

enum UnitType {
  ONE_BHK
  TWO_BHK
  THREE_BHK
  FOUR_BHK
  STUDIO
  PENTHOUSE
  VILLA
  PLOT
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
  VILLA
  TOWNSHIP
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  UPCOMING
  ON_HOLD
}

enum PaymentMethod {
  UPI
  NEFT
  RTGS
  CHEQUE
  CASH
  DEMAND_DRAFT
}

enum BookingStatus {
  INITIATED
  PAYMENT_PENDING
  CONFIRMED
  CANCELLED
}

enum VisitOutcome {
  INTERESTED
  NOT_INTERESTED
  NEED_MORE_TIME
  BOOKED
  NO_SHOW
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  NOTE
  STAGE_CHANGE
  VISIT_SCHEDULED
  VISIT_COMPLETED
  DOCUMENT_SHARED
  AI_ACTION
}

// ── Core Models ────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String
  plan        Plan     @default(STARTER)
  settings    Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  projects    Project[]
  leads       Lead[]
  brokers     Broker[]
  automations Automation[]
  embeddings  Embedding[]
  notifications Notification[]
  auditLogs     AuditLog[]   @relation("TenantAuditLogs")
}

model User {
  id          String   @id @default(cuid())
  tenantId    String
  role        UserRole @default(SALES_AGENT)
  email       String
  name        String
  phone       String?
  agentCode   String?
  password    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  leads       Lead[]     @relation("AssignedLeads")
  activities  Activity[]
  siteVisits  SiteVisit[]
  notifications Notification[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Project {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  location    String
  latitude    Float?
  longitude   Float?
  reraNumber  String?
  type        ProjectType
  status      ProjectStatus @default(ACTIVE)
  launchDate  DateTime?
  amenities   String[]
  upiQrUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  towers              Tower[]
  leads               Lead[]
  media               ProjectMedia[]
  constructionUpdates ConstructionUpdate[]

  @@index([tenantId])
}

model ProjectMedia {
  id        String   @id @default(cuid())
  projectId String
  type      String // BROCHURE, WALKTHROUGH, IMAGE
  url       String
  title     String?
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model ConstructionUpdate {
  id            String   @id @default(cuid())
  projectId     String
  milestoneName String
  description   String?
  photoUrls     String[]
  progressPct   Int      @default(0)
  updateDate    DateTime @default(now())
  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model Tower {
  // ... existing fields ...
  id          String  @id @default(cuid())
  projectId   String
  name        String
  totalFloors Int
  createdAt   DateTime @default(now())

  project     Project @relation(fields: [projectId], references: [id])
  units       Unit[]

  @@index([projectId])
}

model Unit {
  // ... existing fields ...
  id           String     @id @default(cuid())
  towerId      String
  floor        Int
  unitNumber   String
  type         UnitType
  carpetArea   Float
  superArea    Float?
  facing       String?
  basePrice    Float
  totalPrice   Float
  status       UnitStatus @default(AVAILABLE)
  floorPlanUrl String?
  holdUntil    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tower        Tower     @relation(fields: [towerId], references: [id])
  bookings     Booking[]

  @@index([towerId])
  @@index([status])
}

model Lead {
  // ... existing fields ...
  id              String      @id @default(cuid())
  tenantId        String
  projectId       String?
  assignedToId    String?
  brokerId        String?
  name            String
  phone           String
  email           String?
  source          LeadSource  @default(MANUAL)
  stage           LeadStage   @default(NEW_LEAD)
  score           Int?
  scoreLabel      ScoreLabel?
  budgetMin       Float?
  budgetMax       Float?
  preferredBHK    String?
  timeline        String?
  notes           String?
  utmSource       String?
  utmCampaign     String?
  emailOptOut     Boolean     @default(false)
  isArchived      Boolean     @default(false)
  lastActivityAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  project         Project?    @relation(fields: [projectId], references: [id])
  assignedTo      User?       @relation("AssignedLeads", fields: [assignedToId], references: [id])
  broker          Broker?     @relation(fields: [brokerId], references: [id])
  activities      Activity[]
  siteVisits      SiteVisit[]
  bookings        Booking[]
  embeddings      Embedding[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@index([score])
}

model Activity {
  // ... existing fields ...
  id          String       @id @default(cuid())
  leadId      String
  userId      String?
  type        ActivityType
  title       String
  description String?
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  lead        Lead   @relation(fields: [leadId], references: [id])
  user        User?  @relation(fields: [userId], references: [id])

  @@index([leadId])
}

model SiteVisit {
  // ... existing fields ...
  id            String        @id @default(cuid())
  leadId        String
  agentId       String?
  scheduledAt   DateTime
  outcome       VisitOutcome?
  notes         String?
  followUpDate  DateTime?
  checkInTime   DateTime?
  checkOutTime  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lead          Lead   @relation(fields: [leadId], references: [id])
  agent         User?  @relation(fields: [agentId], references: [id])

  @@index([leadId])
  @@index([scheduledAt])
}

model Broker {
  // ... existing fields ...
  id            String  @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  email         String?
  reraNumber    String?
  commissionPct Float   @default(2.0)
  referralCode  String  @unique @default(cuid())
  isActive      Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  leads         Lead[]
  commissions   Commission[]
  disputes      BrokerDispute[]

  @@index([tenantId])
}

model Booking {
  id              String        @id @default(cuid())
  unitId          String
  leadId          String
  buyerName       String
  buyerPhone      String
  buyerEmail      String?
  nomineeName     String?
  bookingAmount   Float
  status          BookingStatus @default(INITIATED)
  isVerified      Boolean       @default(false)
  documents       String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  unit            Unit      @relation(fields: [unitId], references: [id])
  lead            Lead      @relation(fields: [leadId], references: [id])
  payments        Payment[]
  commissions     Commission[]
  coBuyers        CoBuyer[]
  refunds         Refund[]

  @@index([leadId])
  @@index([unitId])
}

model CoBuyer {
  id          String   @id @default(cuid())
  bookingId   String
  name        String
  phone       String
  email       String?
  relation    String? // SPOUSE, PARTNER, PARENT, etc.
  createdAt   DateTime @default(now())

  booking     Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Refund {
  id              String   @id @default(cuid())
  bookingId       String
  amount          Float
  reason          String?
  status          String   @default("PENDING") // PENDING, PROCESSED, REJECTED
  referenceNumber String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  booking         Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Payment {
  // ... existing fields ...
  id              String        @id @default(cuid())
  bookingId       String
  amount          Float
  dueDate         DateTime
  paidAt          DateTime?
  method          PaymentMethod?
  referenceNumber String?
  receiptUrl      String?
  isVerified      Boolean       @default(false) // Approved by Accounts role
  isOverdue       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  booking         Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([dueDate])
}

model Commission {
  // ... existing fields ...
  id          String   @id @default(cuid())
  brokerId    String
  bookingId   String
  amount      Float
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  broker      Broker  @relation(fields: [brokerId], references: [id])
  booking     Booking @relation(fields: [bookingId], references: [id])

  @@index([brokerId])
}

model Automation {
  // ... existing fields ...
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  trigger     String
  conditions  Json     @default("[]")
  actions     Json     @default("[]")
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant      Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Embedding {
  // ... existing fields ...
  id          String   @id @default(cuid())
  tenantId    String
  leadId      String?
  unitId      String?
  embedding   Unsupported("vector(1536)")?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  lead        Lead?  @relation(fields: [leadId], references: [id])

  @@index([tenantId])
}

model Notification {
  // ... existing fields ...
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  message   String
  type      String   @default("SYSTEM")
  leadId    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  user      User   @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([tenantId])
}

model BrokerDispute {
  // ... existing fields ...
  id          String   @id @default(cuid())
  tenantId    String
  brokerId    String
  leadId      String
  reason      String
  status      String   @default("OPEN")
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  broker      Broker @relation(fields: [brokerId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  entity      String
  entityId    String
  oldData     Json?
  newData     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenant      Tenant @relation(fields: [tenantId], references: [id], name: "TenantAuditLogs")
}

