# ============ DATABASE ============
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/waterting?sslmode=require

# ============ AUTH ============
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d

# ============ AI — GROQ ============
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ============ STORAGE — Cloudflare R2 ============
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=waterting-assets
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ============ QUEUE — Upstash Redis ============
REDIS_URL=rediss://default:xxx@your-instance.upstash.io:6379

# ============ EMAIL — Brevo ============
BREVO_API_KEY=xkeysib-xxx
BREVO_SENDER_EMAIL=noreply@waterting.com
BREVO_SENDER_NAME=Waterting CRM

# ============ APP ============
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-app.vercel.app
