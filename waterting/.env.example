# ── Frontend (apps/web/.env.local) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Backend (apps/api/.env) ──────────────────────────────────────
# Database
DATABASE_URL=postgresql://user:pass@host/waterting?sslmode=require

# Auth
JWT_SECRET=super-secret-minimum-32-character-strong-secret-here
JWT_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Redis (Upstash)
REDIS_URL=rediss://your-upstash-url

# Email (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-email
SMTP_PASS=your-brevo-key
SMTP_FROM=noreply@waterting.in

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=waterting-assets
R2_PUBLIC_URL=https://your-r2-public-url

# AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
