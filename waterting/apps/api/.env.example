# ============================================================
# Waterting CRM — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# These must also be set in Render / Vercel dashboards.
# ============================================================

# ---- DATABASE (NeonDB) ----
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ---- AUTH ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-minimum-64-char-random-secret-here"
JWT_EXPIRES_IN="7d"

# ---- AI (Groq — free 14,400 req/day) ----
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxx"

# ---- QUEUE (Upstash Redis) ----
# Get from: https://console.upstash.com → Redis → Details
REDIS_URL="rediss://default:xxx@your-instance.upstash.io:6379"

# ---- FILE STORAGE (Cloudflare R2) ----
# Get from: https://dash.cloudflare.com → R2 → API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="waterting-assets"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ---- EMAIL (Brevo — 300 emails/day free) ----
# Get from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY="xkeysib-xxx"
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="Waterting CRM"

# ---- SERVER ----
NODE_ENV="production"
PORT="3001"
FRONTEND_URL="https://your-app.vercel.app"
