{
  "name": "ai-crm-root",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "waterting",
    "waterting/apps/*",
    "waterting/packages/*"
  ],
  "scripts": {
    "build": "npm run build -w api",
    "prisma:push": "npx prisma db push --schema waterting/prisma/schema.prisma --accept-data-loss",
    "start:prod": "node waterting/apps/api/dist/apps/api/src/main.js",
    "start:full": "npm run build && npm run prisma:push && npm run start:prod"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  }
}
