{
  "name": "ai-crm-root",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "waterting",
    "waterting/apps/*",
    "waterting/packages/*"
  ],
  "scripts": {
    "build:api": "npm run build -w api",
    "prisma:push": "npx prisma db push --schema waterting/prisma/schema.prisma --accept-data-loss",
    "start:api": "npm run prisma:push && node waterting/apps/api/dist/apps/api/src/main.js"
  }
}
